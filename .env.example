# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
RUST_LOG=info
LOG_FORMAT=pretty
# Use LOG_FORMAT=json for production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/myapp
# For sqlx offline mode in CI:
# SQLX_OFFLINE=true

# ─── Redis (optional) ────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-minimum-32-characters-long
# JWT_EXPIRATION_SECS=3600

# ─── External Services (optional) ────────────────────────────────────────────
# EMAIL_API_KEY=your-api-key
# OTLP_ENDPOINT=http://localhost:4317
